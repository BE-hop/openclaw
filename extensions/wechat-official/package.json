{
  "name": "@openclaw/wechat-official",
  "version": "2026.3.9",
  "description": "OpenClaw WeChat Official Account (公众号) channel plugin",
  "type": "module",
  "dependencies": {
    "fast-xml-parser": "5.3.8",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "openclaw": ">=2026.3.2"
  },
  "peerDependenciesMeta": {
    "openclaw": {
      "optional": true
    }
  },
  "openclaw": {
    "extensions": [
      "./index.ts"
    ],
    "channel": {
      "id": "wechat-official",
      "label": "WeChat Official",
      "selectionLabel": "WeChat Official (公众号)",
      "docsPath": "/plugins/community",
      "docsLabel": "community plugins",
      "blurb": "WeChat Official Account webhook + custom service replies.",
      "aliases": [
        "wechat-oa",
        "wcoa"
      ],
      "order": 82,
      "quickstartAllowFrom": true
    },
    "install": {
      "npmSpec": "@openclaw/wechat-official",
      "localPath": "extensions/wechat-official",
      "defaultChoice": "local"
    },
    "releaseChecks": {
      "rootDependencyMirrorAllowlist": [
        "fast-xml-parser"
      ]
    }
  }
}
